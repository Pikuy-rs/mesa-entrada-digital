rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'submissions' (Mesa de Entrada)
    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if request.auth != null; 
    }

    // Reglas para 'evaluaciones_excelencia'
    match /evaluaciones_excelencia/{evaluationId} {
      allow create: if true; 
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }

    // Reglas para 'catedras'
    match /catedras/{catedraId} {
      allow read: if true; // Lectura pública para portales estudiantiles
      allow write: if request.auth != null; 
    }
    
    // Regla global de cierre
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
